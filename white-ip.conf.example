# Активный период работы программы (ЧЧ:ММ-ЧЧ:ММ), можно через полночь (23:00 -> 06:00)
# ЧЧ:ММ задаются в местном времени, см. utc_offset ниже
active_from = 08:00
active_to = 23:00

# Интервал между проверками/попытками, секунды
interval_seconds = 60

# Число неудачных попыток подряд, после которых программа ждёт следующего активного периода
max_attempts = 10

# WAN-интерфейс. Если не задан, определяется автоматически через /rci/show/wans
wan_interface =

# Сервисы проверки внешнего IP (через запятую), пробуются по очереди
check_urls = https://api.ipify.org,https://ipv4.icanhazip.com,https://checkip.amazonaws.com

# Смещение местного времени относительно UTC в часах (например -1, +11).
# Используется для расчёта активного периода (active_from/active_to), если системное
# время роутера не совпадает с нужным часовым поясом. Если не задан — берётся системное время.
utc_offset =
